{
  "schema": "proxbox-api-sse-schema",
  "version": 1,
  "source": {
    "project": "proxbox-api",
    "release": "0.0.17",
    "release_url": "https://github.com/emersonfelipesp/proxbox-api/releases/tag/v0.0.17",
    "modules": [
      "proxbox_api.enum.proxmox",
      "proxbox_api.schemas.stream_messages"
    ]
  },
  "description": "Wire contract for proxbox-api REST/SSE payloads consumed by netbox-proxbox. netbox-proxbox must not import proxbox-api; it validates its local HTTP schema mirrors against this manifest.",
  "enum_values": {
    "BackupMode": ["snapshot", "suspend", "stop"],
    "CompressionAlgorithm": ["zstd", "lzo", "gzip", "0"],
    "NotificationMode": ["always", "failure", "auto", "never"],
    "PBSChangeDetectionMode": ["legacy", "data", "metadata"],
    "ProxmoxVMStatus": ["running", "stopped", "paused", "suspended", "prelaunch"],
    "DiskFormat": ["qcow2", "raw", "vmdk", "subvol"],
    "StreamMessageType": [
      "complete",
      "error",
      "step",
      "discovery",
      "substep",
      "item_progress",
      "phase_summary",
      "error_detail",
      "progress",
      "bootstrap_done",
      "duplicate_name_resolved",
      "hardware_discovery",
      "migrate_dispatched",
      "migrate_progress",
      "migrate_succeeded",
      "migrate_failed"
    ]
  },
  "payload_fields": {
    "DiscoveryMessage": [
      "event",
      "phase",
      "status",
      "message",
      "count",
      "items",
      "progress",
      "metadata"
    ],
    "SubstepMessage": [
      "event",
      "phase",
      "substep",
      "status",
      "message",
      "item",
      "timing",
      "result"
    ],
    "ItemProgressMessage": [
      "event",
      "phase",
      "status",
      "message",
      "item",
      "operation",
      "progress",
      "timing",
      "error",
      "warning"
    ],
    "PhaseSummaryMessage": [
      "event",
      "phase",
      "status",
      "message",
      "result",
      "timing"
    ],
    "ErrorDetailMessage": [
      "event",
      "phase",
      "item",
      "category",
      "message",
      "detail",
      "suggestion",
      "traceback"
    ],
    "DuplicateNameResolvedMessage": [
      "event",
      "cluster",
      "original_name",
      "resolved_name",
      "vmid",
      "suffix_index",
      "operator_renamed"
    ],
    "PlanSummaryMessage": [
      "event",
      "branch_id",
      "verdicts"
    ]
  }
}
